# Backend .gitignore

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables
.env
.env.local
.env.production.local
.env.development.local
.env.test.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
logs/
*.log

# Data files (optional - only if you want to keep them in repo)
# Comment out if you want to share initial data
data/*.json

# Temporary files
tmp/
temp/
